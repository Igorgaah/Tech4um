{
  "name": "tech4um-backend",
  "version": "1.0.0",
  "description": "Tech4um Forum Platform - Backend API with real-time chat",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node database/migrate.js",
    "seed": "node database/seed.js",
    "migrate:seed": "node database/migrate.js && node database/seed.js",
    "test": "jest --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --runInBand"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "globalTeardown": "./tests/globalTeardown.js",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
